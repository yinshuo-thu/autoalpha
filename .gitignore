# AutoAlpha source-control policy:
# keep project code and documentation in Git; keep local data, generated
# submissions, caches, credentials, and built artifacts out of Git.

# Secrets / local config
.env
.env.*
!.env.example
*.pem
*.key
*_key*
*_secret*
secrets/

# Python environments and caches
.venv/
venv/
.conda/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Node / frontend generated assets
frontend/node_modules/
frontend/dist/
frontend/.vite/
node_modules/
dist/

# Logs, process state, temporary files
*.log
*.pid
*.tmp
*.bak
*.swp
cloudflared*.log
cloudflared*.pid
frontend.pid
server.pid
server.public.pid

# macOS / IDE artifacts
.DS_Store
._*
.AppleDouble/
.LSOverride
.vscode/
.idea/
.playwright-cli/
.claude/
scratch/
CLAUDE*.md
CODEX_CHANGELOG.md
scripts/extract_scientech_challenge*
patch_*.py
test_api_*.py
test_feishu_push.py
test_httpx.py
test_requests_long.py
test_llm_factor_gen.py
review_*.md
simulator_TODO_*.md
